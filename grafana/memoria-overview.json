    {
      "type": "timeseries",
      "title": "Request Rate by Route",
      "description": "Per-route request throughput. Identifies which endpoints carry the most load.\n\nRoutes:\n\u2022 /v1/memories (POST) \u2014 Store a single memory\n\u2022 /v1/memories (GET) \u2014 List memories with pagination\n\u2022 /v1/memories/:id (GET) \u2014 Get a single memory by ID\n\u2022 /v1/memories/:id (DELETE) \u2014 Delete a single memory\n\u2022 /v1/memories/:id/correct (PUT) \u2014 Correct memory content (re-embeds)\n\u2022 /v1/memories/:id/feedback (POST) \u2014 Submit feedback signal (useful/irrelevant/outdated/wrong)\n\u2022 /v1/memories/batch (POST) \u2014 Batch store multiple memories\n\u2022 /v1/memories/retrieve (POST) \u2014 Semantic vector retrieval of relevant memories\n\u2022 /v1/memories/search (POST) \u2014 Full-text search across memories\n\u2022 /v1/observe (POST) \u2014 Analyze conversation messages, auto-extract memories (optional LLM)\n\u2022 /v1/consolidate (POST) \u2014 Merge duplicate/similar memories\n\u2022 /v1/governance (POST) \u2014 Run governance (clean stale/low-quality memories)\n\u2022 /v1/profiles/:target_user_id (GET) \u2014 Get user profile summary\n\u2022 /v1/reflect (POST) \u2014 Return candidate memories for summarization\n\u2022 /v1/feedback/stats (GET) \u2014 View feedback statistics\n\u2022 /v1/feedback/by-tier (GET) \u2014 View feedback grouped by trust tier",
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 8,
        "y": 19
      },
      "targets": [
        {
          "expr": "sum by (route) (rate(memoria_http_requests_total[$__rate_interval]))",
          "legendFormat": "{{route}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1,
            "pointSize": 5,
            "spanNulls": false,
            "stacking": {
              "mode": "none"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max",
            "lastNotNull"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "type": "table",
      "title": "Top Routes by Volume",
      "description": "Cumulative request counts per route over the selected time range.\n\nRoutes:\n\u2022 /v1/memories (POST) \u2014 Store a single memory\n\u2022 /v1/memories (GET) \u2014 List memories with pagination\n\u2022 /v1/memories/:id (GET) \u2014 Get a single memory by ID\n\u2022 /v1/memories/:id (DELETE) \u2014 Delete a single memory\n\u2022 /v1/memories/:id/correct (PUT) \u2014 Correct memory content (re-embeds)\n\u2022 /v1/memories/:id/feedback (POST) \u2014 Submit feedback signal (useful/irrelevant/outdated/wrong)\n\u2022 /v1/memories/batch (POST) \u2014 Batch store multiple memories\n\u2022 /v1/memories/retrieve (POST) \u2014 Semantic vector retrieval of relevant memories\n\u2022 /v1/memories/search (POST) \u2014 Full-text search across memories\n\u2022 /v1/observe (POST) \u2014 Analyze conversation messages, auto-extract memories (optional LLM)\n\u2022 /v1/consolidate (POST) \u2014 Merge duplicate/similar memories\n\u2022 /v1/governance (POST) \u2014 Run governance (clean stale/low-quality memories)\n\u2022 /v1/profiles/:target_user_id (GET) \u2014 Get user profile summary\n\u2022 /v1/reflect (POST) \u2014 Return candidate memories for summarization\n\u2022 /v1/feedback/stats (GET) \u2014 View feedback statistics\n\u2022 /v1/feedback/by-tier (GET) \u2014 View feedback grouped by trust tier",
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 16,
        "y": 19
      },
      "targets": [
        {
          "expr": "sum by (route, method) (increase(memoria_http_requests_total[$__range]))",
          "legendFormat": "{{method}} {{route}}"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "transformations": [
        {
          "id": "sortBy",
          "options": {
            "fields": {},
            "sort": [
              {
                "field": "Value",
                "desc": true
              }
            ]
          }
        }
      ]
    },
    {
      "type": "row",
      "title": "HTTP Latency",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 26
      },
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Overall Latency (p50 / p95 / p99)",
      "description": "Aggregate HTTP latency across all routes and sources. p50 = typical request, p95 = worst case for most users, p99 = tail latency.",
      "gridPos": {
        "h": 6,
        "w": 24,
        "x": 0,
        "y": 27
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(memoria_http_request_duration_seconds_bucket[$__rate_interval])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(memoria_http_request_duration_seconds_bucket[$__rate_interval])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(memoria_http_request_duration_seconds_bucket[$__rate_interval])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 1,
            "pointSize": 5,
            "spanNulls": false,
            "stacking": {
              "mode": "none"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max",
            "lastNotNull"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
